# Title
PROJECT_NAME="connexity-evals"

# Frontend
# Used by the backend to generate links in emails to the frontend
# Must NOT end with trailing slash `/`.
SITE_URL=http://localhost:3000

# Whitelisted frontend urls
# SITE_URL is included by default
BACKEND_CORS_ORIGINS="http://localhost,https://localhost,http://localhost:3000,https://localhost:3000,http://localhost:3001,https://localhost:3001"

# Environment: local, staging, production
ENVIRONMENT=local

# Auth
JWT_SECRET_KEY=changethis
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changethis
SESSION_SECRET_KEY=changethis
# 7 days = 24 * 7 = 168 hours
ACCESS_TOKEN_EXPIRE_HOURS=168

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433 # must be free on host
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Set either DATABASE_URL or POSTGRES_* variables, not both. DATABASE_URL overrides POSTGRES_* variables if both are set
# Use DATABASE_URL for Neon.
# Format: postgresql://<username>:<password>@<host>/<database>?<query>
DATABASE_URL=

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# LLM — LiteLLM (generator, judge, simulator)
# https://docs.litellm.ai/docs/providers/openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Bare model + provider when omitted in a call (defaults: gpt-4.1 / openai)
LLM_DEFAULT_MODEL=gpt-4.1
LLM_DEFAULT_PROVIDER=openai
LLM_RETRY_MAX_ATTEMPTS=5
LLM_RETRY_MIN_WAIT_SECONDS=1
LLM_RETRY_MAX_WAIT_SECONDS=60
# Default weight for AI-generated custom metrics
GENERATOR_CUSTOM_METRIC_DEFAULT_WEIGHT=0.15

# Sentry
SENTRY_DSN=

# CLI (connexity-evals)
CONNEXITY_EVALS_API_URL=http://localhost:8000
# JWT from POST /api/v1/login/access-token (same value as auth_cookie)
CONNEXITY_EVALS_API_TOKEN=

